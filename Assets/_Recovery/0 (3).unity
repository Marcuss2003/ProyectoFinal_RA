  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Bienvenido.\nA continuaci\xF3n se veran 4 recuadros en la pantalla.\n\n\xBFQu\xE9
    debes hacer?\n\nTipo de suplemento: Ingresa el tipo de suplemento que vas a analizar
    (Creatina, Proteina, Omega 3, etc.) para personalizar el registro de suplementos
    y llevar un historial de suplementos registrados.\n\nMarca del Suplemento: Escribe
    el nombre de la marca del producto que vas a escanear (ej. Optim nutrition, Dragon
    Pharma, Dymatize, etc).\n\nRegistrar y Escanear: Una vez que registraste el tipo
    y la marca del suplemento toca este bot\xF3n para inicializar los sensores \xF3pticos.\n\nConsulta
    R\xE1pida: Si no deseas guardar el an\xE1lisis en el historial local, puedes
    usar este acceso directo para saltar el registro.\n\nEn la parte de abajo, en
    el panel oscuro, sera el historial, en esta parte se iran guardando los registros
    de cada suplemento que vayas analizando."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
